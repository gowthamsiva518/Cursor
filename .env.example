# Copy to .env and fill in your values.
# .env is loaded by the Flask app, alert engine, and agent (no need to export in shell).

# -----------------------------------------------------------------------------
# OpenSearch (required to read errors from OpenSearch instead of stubs)
# -----------------------------------------------------------------------------
OPENSEARCH_URL=https://app-opensearch-prod.interface.ai

# Per-request timeouts (seconds). Bump if you see ConnectionTimeout /
# ReadTimeoutError, especially for Stream Server APT-only fetches or wide
# bot-engine / integration-manager scans. The "_LONG" variant is used by the
# heavier scan-and-filter queries.
OPENSEARCH_REQUEST_TIMEOUT=60
OPENSEARCH_REQUEST_TIMEOUT_LONG=120

# Index pattern – use default.stream-server.* to match OpenSearch Discover (stream-server logs)
OPENSEARCH_INDEX=default.stream-server.interface-common*

# Optional: timestamp field (default: @timestamp)
OPENSEARCH_TIME_FIELD=@timestamp

# Error code field (numeric code filter)
OPENSEARCH_ERROR_CODE_FIELD=error_code

# Error name field for aggregation/display
OPENSEARCH_ERROR_NAME_FIELD=tenant_name

# Error stack field (for display and exclude filter)
OPENSEARCH_ERROR_STACK_FIELD=rawLog.data.error.stack

# Optional: tenant field for aggregations
# OPENSEARCH_TENANT_FIELD=tenant_name

# --- Filters from Discover URL ---
# Log level filter (level=50 for pino/bunyan error)
OPENSEARCH_LEVEL_FIELD=level
OPENSEARCH_LEVEL_VALUE=50

# Exclude specific error stacks (pipe-separated for multiple)
OPENSEARCH_EXCLUDE_ERROR_STACK=SpeechmaticsRealtimeError: Timed out after 10000ms waiting

# Kubernetes version prefix filter
OPENSEARCH_K8S_VERSION_PREFIX=v5

# Optional: basic auth – only if your OpenSearch cluster requires it
OPENSEARCH_USER=app-platform
OPENSEARCH_PASSWORD=)7]8*6;&mFQg>}%

# Optional: set to 0 to disable SSL certificate verification (e.g. self-signed)
OPENSEARCH_VERIFY_SSL=1

# --- Conversation Logs (for connection_id lookup via request_id) ---
# OPENSEARCH_CONVERSATION_INDEX=conversation-*

# --- Bot Engine Logs (for RCA context_id lookup) ---
# Index pattern for bot engine logs (leave empty to skip bot engine log lookup)
# OPENSEARCH_BOT_ENGINE_INDEX=bot-engine.default-*
# Field(s) containing contextId in bot-engine logs.  Comma-separated list — bot-engine
# emits the contextId at one of two paths depending on the moduleName, so by default
# we match either.  Set to a single path to restrict the search.
# OPENSEARCH_BOT_ENGINE_CONTEXT_FIELD=rawLog.data.event.request.meta.contextId,rawLog.data.contextId

# --- Integration Manager default logs (by connectionId; optional) ---
# Prod Discover (pick index pattern name from the UI for OPENSEARCH_INTEGRATION_MANAGER_INDEX):
# https://app-opensearch-prod.interface.ai/_dashboards/app/data-explorer/discover#?_a=(discover:(columns:!(_source),isDirty:!f,sort:!()),metadata:(indexPattern:a6cffd50-d18c-11ef-ae32-6f5eb69dfd82,view:discover))&_g=(filters:!(),refreshInterval:(pause:!t,value:0),time:(from:now-15m,to:now))&_q=(filters:!(),query:(language:kuery,query:''))
# OPENSEARCH_INTEGRATION_MANAGER_INDEX=integration-manager.default-*

# --- Stream Server default logs (by contextId, APT identifier, or Connection ID; optional) ---
# Powers the "Stream Server Default Logs" sub-agent. Replay a single voice/chat
# session by rawLog.data.contextId, drill into one Twilio/SIP connection via
# rawLog.data.action.event.connection.id, OR pull all logs for one APT (bot) in
# a time window via rawLog.data.action.event.client.data.name. All three filters
# can be combined. If OPENSEARCH_STREAM_SERVER_INDEX is unset, the agent falls
# back to OPENSEARCH_INDEX above.
# Prod Discover (pick index pattern name from the UI):
# https://app-opensearch-prod.interface.ai/_dashboards/app/data-explorer/discover#?_a=(discover:(columns:!(_source),isDirty:!f,sort:!()),metadata:(indexPattern:fdf3c370-df3f-11f0-8651-09c57e0237fe,view:discover))&_g=(filters:!(),refreshInterval:(pause:!t,value:0),time:(from:now-15m,to:now))&_q=(filters:!(),query:(language:kuery,query:''))
# OPENSEARCH_STREAM_SERVER_INDEX=default.stream-server.*
# OPENSEARCH_STREAM_SERVER_CONTEXT_FIELD=rawLog.data.contextId
# OPENSEARCH_STREAM_SERVER_APT_FIELD=rawLog.data.action.event.client.data.name
# OPENSEARCH_STREAM_SERVER_CONNECTION_FIELD=rawLog.data.action.event.connection.id

# -----------------------------------------------------------------------------
# Lens / Kubernetes (bot engine pod restarts)
# Reads from ~/.kube/config by default; set these to customize.
# -----------------------------------------------------------------------------
# KUBE_CONFIG_PATH=~/.kube/config
# KUBE_CONTEXT=production
# KUBE_NAMESPACE=default
# KUBE_POD_FILTER=bot-engine
# KUBE_LABEL_SELECTOR=app=bot-engine

# -----------------------------------------------------------------------------
# Twilio (call logs + connection status for RCA)
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBERS=

# -----------------------------------------------------------------------------
# LLM — OpenAI-compatible Chat Completions (RCA, rephrase, Bot Engine Analyse Logs)
# Default host is OpenAI; set OPENAI_BASE_URL for Groq, OpenRouter, Azure, or Ollama.
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_RETRIES=5
# OPENAI_VERIFY_SSL=1
# If you see SSLCertVerificationError on Windows/VPN, try: pip install -U certifi requests
# Still failing? OPENAI_VERIFY_SSL=0 (insecure; corporate MITM proxies only)
#
# Groq (use API host, not the browser console — wrong host causes SSL / connection errors):
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
#
# Local Ollama (no key): OPENAI_BASE_URL=http://127.0.0.1:11434/v1  OPENAI_MODEL=llama3.2
#
# Per-request token budget for Analyse Logs (input + output, including a small
# safety margin). Auto-detected if unset: 5500 for Groq (free/on-demand tier
# is ~6000 TPM on llama-3.1-8b-instant), 60000 elsewhere. Set this if you
# upgraded to a higher-TPM tier, or lower it if you keep hitting HTTP 413.
# LLM_TPM_BUDGET=5500

# -----------------------------------------------------------------------------
# Slack (send RCA to channel, slash commands)
# -----------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_LISTEN_CHANNEL=#stream-prod-alerts
# SLACK_CHANNEL=#stream-server-alerts-triage-agent
# SLACK_ENABLED=false
#
# Socket Mode listener (auto-RCA on alert messages)
# SLACK_APP_TOKEN=xapp-...
# SLACK_LISTENER_ENABLED=false
# SLACK_ALERT_KEYWORDS=alert,error,incident,outage,failure,down
# SLACK_ALERT_TIME_MINUTES=15

# -----------------------------------------------------------------------------
# PostgreSQL (optional — "Database check" in the assistant UI)
# Use DATABASE_URL *or* DB_HOST + DB_USER (+ DB_NAME, DB_PASSWORD). URL wins if both set.
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=myuser
# DB_PASSWORD=secret
# DB_SSLMODE=prefer

# -----------------------------------------------------------------------------
# Symitar Core / SymXchange (symitar_api_agent.py — same keys as IM ConfigMap)
# -----------------------------------------------------------------------------
# SYM_WSDL_DIRECTORY=https://core.example.com/symitar/servlet
# SYM_VERSION=2023.00
# SYM_CORE_API_DEVICE_TYPE=0
# SYM_CORE_API_DEVICE_NUMBER=1
# SYM_CORE_API_PASSWORD=secret
# SYM_VERIFY_SSL=0
# SYM_HTTP_TIMEOUT_SEC=60
# SYM_MESSAGE_ID=123456

# -----------------------------------------------------------------------------
# Next.js only: point agent requests to Flask (optional)
# -----------------------------------------------------------------------------
# AGENT_API_URL=http://127.0.0.1:5000
