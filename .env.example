# Copy to .env and fill in your values.
# .env is loaded by the Flask app, alert engine, and agent (no need to export in shell).

# -----------------------------------------------------------------------------
# OpenSearch (required to read errors from OpenSearch instead of stubs)
# -----------------------------------------------------------------------------
OPENSEARCH_URL=https://app-opensearch-prod.interface.ai

# Index pattern – use default.stream-server.* to match OpenSearch Discover (stream-server logs)
OPENSEARCH_INDEX=default.stream-server.interface-common*

# Optional: timestamp field (default: @timestamp)
OPENSEARCH_TIME_FIELD=@timestamp

# Error code field (numeric code filter)
OPENSEARCH_ERROR_CODE_FIELD=error_code

# Error name field for aggregation/display
OPENSEARCH_ERROR_NAME_FIELD=tenant_name

# Error stack field (for display and exclude filter)
OPENSEARCH_ERROR_STACK_FIELD=rawLog.data.error.stack

# Optional: tenant field for aggregations
# OPENSEARCH_TENANT_FIELD=tenant_name

# --- Filters from Discover URL ---
# Log level filter (level=50 for pino/bunyan error)
OPENSEARCH_LEVEL_FIELD=level
OPENSEARCH_LEVEL_VALUE=50

# Exclude specific error stacks (pipe-separated for multiple)
OPENSEARCH_EXCLUDE_ERROR_STACK=SpeechmaticsRealtimeError: Timed out after 10000ms waiting

# Kubernetes version prefix filter
OPENSEARCH_K8S_VERSION_PREFIX=v5

# Optional: basic auth – only if your OpenSearch cluster requires it
OPENSEARCH_USER=app-platform
OPENSEARCH_PASSWORD=)7]8*6;&mFQg>}%

# Optional: set to 0 to disable SSL certificate verification (e.g. self-signed)
OPENSEARCH_VERIFY_SSL=1

# --- Conversation Logs (for connection_id lookup via request_id) ---
# OPENSEARCH_CONVERSATION_INDEX=conversation-*

# --- Bot Engine Logs (for RCA context_id lookup) ---
# Index pattern for bot engine logs (leave empty to skip bot engine log lookup)
# OPENSEARCH_BOT_ENGINE_INDEX=bot-engine.default-*
# Field containing contextId in bot engine logs
# OPENSEARCH_BOT_ENGINE_CONTEXT_FIELD=rawLog.data.event.request.meta.contextId

# -----------------------------------------------------------------------------
# Lens / Kubernetes (bot engine pod restarts)
# Reads from ~/.kube/config by default; set these to customize.
# -----------------------------------------------------------------------------
# KUBE_CONFIG_PATH=~/.kube/config
# KUBE_CONTEXT=production
# KUBE_NAMESPACE=default
# KUBE_POD_FILTER=bot-engine
# KUBE_LABEL_SELECTOR=app=bot-engine

# -----------------------------------------------------------------------------
# Twilio (call logs + connection status for RCA)
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBERS=

# -----------------------------------------------------------------------------
# OpenAI (AI-powered RCA summary)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Slack (send RCA to channel, slash commands)
# -----------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL=#stream-server-alerts
# SLACK_ENABLED=false
#
# Socket Mode listener (auto-RCA on alert messages)
# SLACK_APP_TOKEN=xapp-...
# SLACK_LISTENER_ENABLED=false
# SLACK_ALERT_KEYWORDS=alert,error,incident,outage,failure,down
# SLACK_ALERT_TIME_MINUTES=15

# -----------------------------------------------------------------------------
# Next.js only: point agent requests to Flask (optional)
# -----------------------------------------------------------------------------
# AGENT_API_URL=http://127.0.0.1:5000
